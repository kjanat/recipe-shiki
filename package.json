{
	"name": "recipe-shiki",
	"version": "0.1.0",
	"description": "Shiki language pack for the recipe (.recipe / .rx) pharmacological notation.",
	"keywords": [
		"shiki",
		"textmate",
		"grammar",
		"recipe",
		"rx",
		"prescription",
		"pharmacology",
		"syntax-highlighting"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/recipe-shiki.git"
	},
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"type": "module",
	"imports": {
		"#recipki": "./src/index.ts"
	},
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist/**",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsdown",
		"build:demo": "bun run demo/highlight.ts",
		"check": "biome check",
		"fmt": "dprint fmt",
		"lint": "biome lint",
		"prepack": "bun run build",
		"prestart": "bun build:demo",
		"start": "bun demo/output.html",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"recipe-tmlanguage": "npm:@jsr/kjanat__recipe-tmlanguage@^0.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@shikijs/types": "^3",
		"@types/bun": "^1.3.13",
		"dprint": "^0.54.0",
		"shiki": "^4.0.2",
		"tsdown": "^0.15.0",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"shiki": ">=3"
	},
	"peerDependenciesMeta": {
		"shiki": {
			"optional": true
		}
	},
	"packageManager": "bun@1.3.13",
	"trustedDependencies": [
		"recipe-tmlanguage"
	]
}
