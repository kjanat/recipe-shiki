{
	"name": "recipe-shiki",
	"version": "0.2.2",
	"description": "Shiki language pack for the recipe (.recipe) pharmacological notation.",
	"keywords": [
		"shiki",
		"textmate",
		"grammar",
		"recipe",
		"prescription",
		"pharmacology",
		"syntax-highlighting"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/recipe-shiki.git"
	},
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"type": "module",
	"imports": {
		"#recipki": "./src/index.node.ts"
	},
	"exports": {
		".": "./dist/mod.js",
		"./package.json": "./package.json"
	},
	"types": "./dist/mod.d.ts",
	"files": [
		"dist/**",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsdown",
		"build:demo": "bun run demo/highlight.ts",
		"check": "biome check",
		"fmt": "dprint fmt",
		"lint": "biome lint",
		"prepack": "bun run build",
		"prestart": "bun build:demo",
		"start": "bun demo/output.html",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@shikijs/types": "^4.3.0",
		"@types/bun": "^1.3.14",
		"dprint": "^0.55.0",
		"recipe-tmlanguage": "^0.3.5",
		"shiki": "^4.3.0",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@shikijs/types": ">=3",
		"shiki": ">=3"
	},
	"peerDependenciesMeta": {
		"@shikijs/types": {
			"optional": true
		},
		"shiki": {
			"optional": true
		}
	},
	"packageManager": "bun@1.3.14",
	"inlinedDependencies": {
		"recipe-tmlanguage": "0.3.5"
	},
	"trustedDependencies": [
		"recipe-tmlanguage"
	]
}
